# Embedding Configuration
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=auto  # Options: cuda, cpu, auto

# LLM Configuration
LLM_MODEL=gemini-2.0-flash  # Options: gemini-2.0-flash, gpt-4o, gpt-4o-mini, local-model-name
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Vector Store Configuration
VECTOR_STORE_TYPE=faiss  # Options: faiss, simple
INDEX_PATH=./data/index
DOCS_PATH=./data/documents

# Retrieval Configuration
RETRIEVAL_MODE=multi_stage  # Options: basic, multi_stage
RETRIEVAL_TOP_K=5
RETRIEVAL_INITIAL_K=20
USE_ADAPTIVE=true

# Arabic Morphology
CAMEL_DB=arablmsr  # Options: arablmsr, arabic, calima-db-msa

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Gradio UI Configuration
GRADIO_PORT=7860
GRADIO_SHARE=false

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Cache Configuration
EMBEDDING_CACHE_SIZE=10000
EMBEDDING_CACHE_TTL=24  # hours
QUERY_CACHE_SIZE=1000
QUERY_CACHE_TTL=6  # hours

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100
